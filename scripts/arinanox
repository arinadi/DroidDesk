#!/data/data/com.termux/files/usr/bin/bash
# ═══════════════════════════════════════════════════════════════
# arinanoX — Unified CLI
# Usage: arinanox <command> [args...]
# ═══════════════════════════════════════════════════════════════
set -euo pipefail

ARINANOX_DIR="${ARINANOX_DIR:-$HOME/.arinanox}"
SCRIPTS_DIR="$ARINANOX_DIR/scripts"
VERSION="1.0"

# ── Bootstrap (first-run) ───────────────────────────────────
if [ ! -d "$ARINANOX_DIR/scripts" ]; then
    echo ">>> Bootstrapping arinanoX..."
    curl -sL https://raw.githubusercontent.com/arinadi/arinanoX/main/bootstrap.sh | bash
    exit $?
fi

usage() {
    cat <<EOF
arinanoX v${VERSION} — Your phone is a Linux workstation.

  arinanox start         Start desktop (PulseAudio → X11 → virgl → XFCE)
  arinanox stop          Stop desktop
  arinanox status        System status (image, storage, snapshots)
  arinanox doctor        Full health-check
  arinanox update        Full update (⚠️ resets core, preserves user layer)
  arinanox rollback      Rollback core image to arinanox-prev
  arinanox backup        Backup /home/admin to /sdcard/arinanox-backup
  arinanox restore       Restore backup from /sdcard
  arinanox store         APT Store GUI (install/search/upgrade packages)
  arinanox snapshot      Snapshot user home (hardlink, instant, 3 retained)
  arinanox install       Add packages via manifest (declarative user layer)
  arinanox help          Show this help

Snapshots:  arinanox snapshot list|create|restore <id>
EOF
    exit 0
}

# ── Command dispatcher ──────────────────────────────────────
CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
    # ── Desktop ──
    start)
        exec bash "$HOME/start.sh"
        ;;
    stop)
        exec bash "$HOME/stop.sh"
        ;;

    # ── Status ──
    status)
        exec bash "$SCRIPTS_DIR/doctor.sh"
        ;;
    doctor)
        exec bash "$SCRIPTS_DIR/doctor.sh"
        ;;

    # ── Core management ──
    update)
        echo ">>> arinanox update — full reinstall"
        echo "    ⚠ Core layer resets. User layer will be re-applied."
        echo ""
        read -p "    Continue? [y/N] " confirm
        case "$confirm" in [yY]*) ;; *) echo "    Cancelled."; exit 0 ;; esac
        
        # Run bootstrap
        curl -sL https://raw.githubusercontent.com/arinadi/arinanoX/main/bootstrap.sh | bash
        
        # Re-apply user manifest if exists
        MANIFEST="$ARINANOX_DIR/user-manifest.yaml"
        if [ -f "$MANIFEST" ]; then
            echo ">>> Applying user manifest..."
            bash "$SCRIPTS_DIR/manifest-apply.sh"
        fi
        echo ">>> Done. Start: arinanox start"
        ;;

    rollback)
        ROLLBACK_SCRIPT="$SCRIPTS_DIR/proot-rollback.sh"
        if [ -f "$ROLLBACK_SCRIPT" ]; then
            exec bash "$ROLLBACK_SCRIPT"
        else
            echo "✗ Rollback script not found. Run: arinanox update"
            exit 1
        fi
        ;;

    # ── Package management ──
    store)
        STORE_SCRIPT="$ARINANOX_DIR/tools/apt-store.sh"
        if [ -f "$STORE_SCRIPT" ]; then
            exec bash "$STORE_SCRIPT"
        else
            echo "✗ APT Store not found. Run: arinanox update"
            exit 1
        fi
        ;;

    install)
        echo ">>> arinanox install — declarative user layer"
        echo ""
        
        # Check for manifest
        MANIFEST="$ARINANOX_DIR/user-manifest.yaml"
        if [ ! -f "$MANIFEST" ]; then
            echo "    No user-manifest.yaml found."
            echo "    Generate one: arinanox install --generate"
            exit 1
        fi
        
        # Parse packages from manifest and install
        if grep -q "^packages:" "$MANIFEST" 2>/dev/null; then
            echo "    Installing packages from manifest..."
            # Extract package names
            PKGS=$(grep -E "^\s+- " "$MANIFEST" | sed 's/^\s*- //' | grep -v "^#" | tr '\n' ' ')
            if [ -n "$PKGS" ]; then
                echo "    Packages: $PKGS"
                proot-distro login arinanox -- bash -c "sudo apt-get update -qq && sudo apt-get install -y $PKGS" || true
                echo "    ✓ Done"
            else
                echo "    • No packages in manifest"
            fi
        fi
        ;;

    # ── Backup / Restore ──
    backup)
        BACKUP_DIR="/sdcard/arinanox-backup"
        echo ">>> Backing up /home/admin to ${BACKUP_DIR}..."
        
        if [ ! -d /sdcard ]; then
            echo "    ✗ /sdcard not accessible. Run: termux-setup-storage"
            exit 1
        fi
        
        ROOTFS="/data/data/com.termux/files/usr/var/lib/proot-distro/containers/arinanox/rootfs"
        if [ ! -d "$ROOTFS/home/admin" ]; then
            echo "    ✗ No arinanox container. Run: arinanox update"
            exit 1
        fi
        
        mkdir -p "$BACKUP_DIR"
        rsync -av --delete "$ROOTFS/home/admin/" "$BACKUP_DIR/home/" 2>&1 | tail -3
        echo "    ✓ Backup complete: $BACKUP_DIR"
        ;;

    restore)
        BACKUP_DIR="/sdcard/arinanox-backup"
        echo ">>> Restoring from ${BACKUP_DIR}..."
        
        if [ ! -d "$BACKUP_DIR/home" ]; then
            echo "    ✗ No backup found at $BACKUP_DIR/home"
            echo "    Run: arinanox backup"
            exit 1
        fi
        
        ROOTFS="/data/data/com.termux/files/usr/var/lib/proot-distro/containers/arinanox/rootfs"
        if [ ! -d "$ROOTFS/home/admin" ]; then
            echo "    ✗ No arinanox container. Run: arinanox update"
            exit 1
        fi
        
        echo "    ⚠ This will overwrite /home/admin."
        read -p "    Continue? [y/N] " confirm
        case "$confirm" in [yY]*) ;; *) echo "    Cancelled."; exit 0 ;; esac
        
        rsync -av --delete "$BACKUP_DIR/home/" "$ROOTFS/home/admin/" 2>&1 | tail -3
        echo "    ✓ Restore complete."
        ;;

    # ── Snapshots ──
    snapshot)
        SNAPSHOT_SCRIPT="$SCRIPTS_DIR/user-snapshot.sh"
        if [ -f "$SNAPSHOT_SCRIPT" ]; then
            exec bash "$SNAPSHOT_SCRIPT" "$@"
        else
            echo "    ✗ Snapshot script not found. Run: arinanox update"
        fi
        ;;

    help|--help|-h)
        usage
        ;;

    *)
        echo "arinanox: unknown command '$CMD'"
        echo "Run: arinanox help"
        exit 1
        ;;
esac
